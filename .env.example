# tg — пример переменных окружения. Скопируй в .env (он в .gitignore) при необходимости.
# Bun загружает .env автоматически. Все переменные ОПЦИОНАЛЬНЫ — есть рабочие умолчания.

# --- Telegram API (по умолчанию встроены общие креды; свои надёжнее) ---
# TG_API_ID=
# TG_API_HASH=

# --- Управляющий канал: откуда агент берёт твои команды ("me" = Избранное) ---
# TG_CONTROL_CHAT=me

# --- Движок: claude (по умолчанию) или codex ---
# TG_AGENT=claude
# TG_MODEL=opus
# TG_EFFORT=            # low|medium|high|xhigh|max

# --- Тайминги ---
# TG_DETECT_SECONDS=3   # период детектора чатов/мониторов/расписаний
# TG_INTERVAL=60        # (легаси) интервал, если используется

# --- Хаб (обычно НЕ задавать — порт/токен берутся из data/service.lock) ---
# TG_HUB_PORT=8765

# --- Аутентификация движка ---
# ВНИМАНИЕ: если задать ANTHROPIC_API_KEY/ANTHROPIC_AUTH_TOKEN — оплата Claude пойдёт
# через API, а не через локальную подписку Claude Code. Для подписки оставь пустым.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=       # для Codex (или используй `codex login`)
